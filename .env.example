# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional - model routing
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INTENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARY_FALLBACK_MODELS=openai/gpt-oss-120b,meta-llama/llama-4-scout-17b-16e-instruct

# Optional - local agent logs
AGENT_LOG_DIR=logs

# Optional - LangFuse observability (https://langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
